<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>{{ seoTitle or title or "Arafen Kabir Shovon" }}</title>
  <meta name="description" content="{{ description or 'Growth marketing, GTM strategy, SEO, content, and free tools for B2B marketers.' }}">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {% if canonical %}<link rel="canonical" href="{{ canonical }}">{% endif %}
  <meta property="og:title" content="{{ seoTitle or title or 'Arafen Kabir Shovon' }}">
  <meta property="og:description" content="{{ description or 'Growth marketing, GTM strategy, SEO, content, and free tools for B2B marketers.' }}">
  {% if featuredImage %}<meta property="og:image" content="{{ featuredImage }}">{% endif %}
  <meta property="og:type" content="website">
  <link rel="icon" href="/favicon.png">
  <style>
    :root { --bg:#0f1020; --card:#ffffff; --text:#1f2937; --muted:#6b7280; --brand:#3E3691; --accent:#BF2629; --line:#e5e7eb; }
    * { box-sizing: border-box; }
    body { margin:0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background:#f8fafc; color:var(--text); line-height:1.7; }
    header { background:var(--bg); color:#fff; }
    .nav { max-width:1100px; margin:0 auto; padding:18px 22px; display:flex; align-items:center; justify-content:space-between; gap:20px; }
    .brand { color:#fff; text-decoration:none; font-weight:800; letter-spacing:-0.02em; }
    .links { display:flex; gap:18px; flex-wrap:wrap; }
    .links a { color:#dbeafe; text-decoration:none; font-weight:600; font-size:15px; }
    .links a:hover { color:#fff; }
    main { max-width:920px; margin:48px auto; padding:0 22px; }
    article, section { background:var(--card); border:1px solid var(--line); border-radius:22px; padding:34px; box-shadow:0 18px 45px rgba(15, 16, 32, .06); }
    h1 { margin:0 0 18px; font-size:clamp(34px, 5vw, 56px); line-height:1.05; letter-spacing:-0.05em; color:#111827; }
    h2 { margin-top:28px; line-height:1.2; letter-spacing:-0.03em; }
    p { font-size:18px; color:#374151; }
    a { color:var(--brand); }
    img { max-width:100%; height:auto; border-radius:16px; }
    .post-meta { color:var(--muted); font-size:14px; margin-bottom:22px; }
    footer { max-width:1100px; margin:40px auto; padding:0 22px 40px; color:var(--muted); }
    @media (max-width:720px) { .nav { align-items:flex-start; flex-direction:column; } article, section { padding:24px; border-radius:18px; } }
  </style>
</head>
<body>
  <header>
    <nav class="nav">
      <a class="brand" href="/">Arafen Kabir Shovon</a>
      <div class="links">
        <a href="/">Home</a>
        <a href="/blog/">Blog</a>
        <a href="/resources/">Resources</a>
        <a href="/#contact">Contact</a>
      </div>
    </nav>
  </header>
  <main>
    {{ content | safe }}
  </main>
  <footer>
    <p>© 2026 Arafen Kabir Shovon. All rights reserved.</p>
  </footer>
</body>
</html>
